# Copy to .env (gitignored). These also work as Streamlit Cloud secrets.

# Unlocks the Dev Lab page
DEV_PASSWORD=change-me

# Set to false on public deploys to remove the Dev Lab from the nav entirely
DEV_LAB_ENABLED=true

# Cloud deploys only: URL to download warehouse/basketball.duckdb from on
# first boot (e.g. a GitHub Release asset). Leave unset locally.
# WAREHOUSE_URL=https://github.com/<you>/<repo>/releases/download/data-v1/basketball.duckdb
